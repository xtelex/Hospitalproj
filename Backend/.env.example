# Never commit real secrets. Use environment variables (e.g., Render/Vercel env settings)
# or a local `.env` file that is gitignored.

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/hospital

# PayMongo
# Use your *Secret Key* here (sk_test_... or sk_live_...).
PAYMONGO_SECRET_KEY=

# Webhook signing secret from PayMongo dashboard (used to verify webhook requests).
PAYMONGO_WEBHOOK_SECRET=whsec_xxx

# Optional: "test" or "live". If unset, webhook verifier accepts either signature (te/li) if valid.
PAYMONGO_MODE=test

# Frontend URL for success/cancel redirects.
FRONTEND_URL=http://localhost:5173

