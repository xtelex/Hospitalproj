# Root ignores (Frontend/Backend have their own .gitignore too)

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/build/

# Env / secrets
.env
**/.env
**/.env.*
!**/.env.example

# Local data
**/.data/

# Logs
logs/
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

